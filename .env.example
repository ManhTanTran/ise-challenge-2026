OPENROUTER_API_KEY=

# === Model selection (approach 3) ============================================
# Budget-friendly default for ~$20 on OpenRouter. A full run over the sample
# questions costs well under $1 with these, so $20 covers many tuning runs.
# Prices change: verify current rates at https://openrouter.ai/models

# Reasoning (Buoc 4) + table pandas codegen (Buoc 3). Strong, cheap, big context.
OPENROUTER_MODEL=google/gemini-2.5-flash
# Question analysis (Buoc 1): high-volume, simple JSON classification -> cheapest.
ISE_ANALYSIS_MODEL=google/gemini-2.5-flash-lite
# Image QA (Buoc 3): needs native vision. Gemini 2.5 Flash handles images cheaply.
ISE_VISION_MODEL=google/gemini-2.5-flash

# Alternative (OpenAI, very reliable JSON, still cheap). Swap the 3 lines above:
#   OPENROUTER_MODEL=openai/gpt-4.1-mini
#   ISE_ANALYSIS_MODEL=openai/gpt-4.1-nano
#   ISE_VISION_MODEL=openai/gpt-4.1-mini
# NOTE: model slugs change over time. If you get 404 "No endpoints found",
# check the current id at https://openrouter.ai/models

# Embedding runs LOCALLY (sentence-transformers, NOT OpenRouter, no cost).
# Needs: pip install sentence-transformers faiss-cpu
ISE_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# === Optional path overrides =================================================
DATA_LAKE_DIR=
QUESTION_PATH=
OUTPUT_DIR=
FILE_INDEX_PATH=
ISE_VISION_CACHE_DIR=
